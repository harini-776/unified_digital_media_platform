# =============================================================================
# TrustMedia API — Environment template
# =============================================================================
# Copy this file to .env and fill in real values:
#     cp .env.example .env
#
# .env is gitignored. Never commit a populated .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (REQUIRED — no defaults; boot fails if missing)
# -----------------------------------------------------------------------------
# Use a strong password. The legacy default postgres:postgres@localhost is NOT
# acceptable. For local dev, set a non-trivial password and use it here.
DATABASE_URL=postgresql://trustmedia:CHANGE_ME@localhost:5432/deepfake_trust
DATABASE_URL_ASYNC=postgresql+asyncpg://trustmedia:CHANGE_ME@localhost:5432/deepfake_trust

# -----------------------------------------------------------------------------
# Auth (REQUIRED — JWT_SECRET is validated at startup)
# -----------------------------------------------------------------------------
# Must be at least 32 characters and not in the weak-strings blocklist.
# Generate with:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# -----------------------------------------------------------------------------
# Redis / Celery
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins. Never use "*" with allow_credentials.
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# DEBUG=true exposes /docs and /redoc; set to false in any shared environment.
DEBUG=true

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
MAX_UPLOAD_SIZE_MB=500

# -----------------------------------------------------------------------------
# IPFS / Pinata (optional — leave blank if not using)
# -----------------------------------------------------------------------------
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_JWT=

# -----------------------------------------------------------------------------
# Blockchain (optional)
# -----------------------------------------------------------------------------
RPC_URL=https://rpc-amoy.polygon.technology
CONTRACT_ADDRESS=
PRIVATE_KEY=

# -----------------------------------------------------------------------------
# AI / Models
# -----------------------------------------------------------------------------
MODEL_DEVICE=cpu
MODEL_BATCH_SIZE=16
DEMO_MODE=false
